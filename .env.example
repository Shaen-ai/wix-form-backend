APP_NAME="Form App"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=form_app
DB_USERNAME=root
DB_PASSWORD=

JWT_SECRET=your-jwt-secret-for-wix-instance-tokens

# Mail (use "log" for development; "smtp" or "sendmail" for production)
MAIL_MAILER=log
MAIL_FROM_ADDRESS="noreply@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# For Postfix on host server (local delivery, no TLS):
# MAIL_MAILER=smtp
# MAIL_HOST=127.0.0.1
# MAIL_PORT=25
# MAIL_USERNAME=
# MAIL_PASSWORD=
# MAIL_ENCRYPTION=     (empty or "null" = no encryption for local Postfix)

# Alternative: use sendmail (typically Postfix on Linux):
# MAIL_MAILER=sendmail
# MAIL_SENDMAIL_PATH="/usr/sbin/sendmail -bs"

# Feature request emails go to this address
MAIL_FEATURE_REQUEST_RECIPIENT=info@nextechspires.com

# reCAPTCHA Enterprise (recommended)
RECAPTCHA_PROJECT_ID=your-google-cloud-project-id
RECAPTCHA_API_KEY=your-google-cloud-api-key
RECAPTCHA_SITE_KEY=your-recaptcha-site-key

# Legacy reCAPTCHA v2/v3 (fallback if Enterprise not configured)
RECAPTCHA_SECRET=your-recaptcha-secret-key

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

FILESYSTEM_DISK=local

QUEUE_CONNECTION=database

CACHE_STORE=file
SESSION_DRIVER=file
